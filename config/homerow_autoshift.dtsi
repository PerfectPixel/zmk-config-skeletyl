#define HOMEROW_MOD_AUTOSHIFT(NAME, KEY, MODIFIER) \
  behaviors { \
    hmas_##NAME: behavior_inner_##NAME { \
        compatible = "zmk,behavior-hold-tap"; \
        #binding-cells = <2>; \
        tapping_term_ms = <TAPPING_TERM>; \
        quick_tap_ms = <0>; \
        flavor = "tap-preferred"; \
        bindings = <&m_mod_or_shifted_key_##NAME>, <&kp>; \
    }; \
    bo_##NAME: behavior_outer_##NAME { \
        compatible = "zmk,behavior-hold-tap"; \
        #binding-cells = <2>; \
        tapping_term_ms = <TAPPING_TERM_HOME_ROW_MODS>; \
        quick_tap_ms = <0>; \
        flavor = "tap-preferred"; \
        bindings = <&m_mod_##NAME>, <&m_shifted_key_##NAME>; \
    }; \
  }; \
  ZMK_MACRO(m_mod_##NAME, \
      bindings = <&macro_press ##MODIFIER &macro_pause_for_release &macro_release ##MODIFIER>; \
  ) \
  ZMK_MACRO(m_shifted_key_##NAME, \
      bindings = <&macro_press &kp LS(##KEY) &macro_pause_for_release &macro_release &kp LS(##KEY)>; \
  ) \
  ZMK_MACRO(m_mod_or_shifted_key_##NAME, \
      bindings = <&macro_press &bo_##NAME 0 0 &macro_pause_for_release &macro_release &bo_##NAME 0 0>; \
  ) \

HOMEROW_MOD_AUTOSHIFT(l_ctrl_a,  A, &kp LC(LCTRL))
HOMEROW_MOD_AUTOSHIFT(l_alt_r,   R, &kp LA(LALT))
HOMEROW_MOD_AUTOSHIFT(l_gui_s,   S, &kp LG(LGUI))
HOMEROW_MOD_AUTOSHIFT(l_shift_t, T, &kp LS(LSHIFT))

HOMEROW_MOD_AUTOSHIFT(r_shift_n, N, &kp RS(RSHIFT))
HOMEROW_MOD_AUTOSHIFT(r_gui_e,   E, &kp RG(RGUI))
HOMEROW_MOD_AUTOSHIFT(r_alt_i,   I, &kp LA(LALT))
HOMEROW_MOD_AUTOSHIFT(r_ctrl_o,  O, &kp RC(RCTRL))
